generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  pin       String
  secretpin String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
